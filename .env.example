# Copy this file to .env and fill in your values before running ./scripts/up.sh
# .env is git-ignored and must never be committed.

# =============================================================================
# PostgreSQL
# =============================================================================

# Name of the application database created on first start
POSTGRESQL_DB=myapp

# Superuser account created on first start
POSTGRESQL_USER=myapp_user

# Strong random password — minimum 32 characters
# Generate one: openssl rand -base64 32
POSTGRESQL_PASSWORD=change_me_use_openssl_rand

# CPU limit for the PostgreSQL container (Docker deploy.resources)
# Examples: "1", "2", "0.5"
POSTGRESQL_CPUS=2

# Memory limit for the PostgreSQL container
# Keep shared_buffers in postgresql.conf at ~25% of this value.
# Examples: "1G", "2G", "512M"
POSTGRESQL_MEMORY=2G

# =============================================================================
# PgBouncer
# =============================================================================

# Port published on the host. Clients connect to this port.
PGBOUNCER_PORT=6432

# Pooling mode:
#   session     — one server connection per client session (safe, lower throughput)
#   transaction — one server connection per transaction (recommended for most apps)
#   statement   — one server connection per statement (avoid unless you know why)
PGBOUNCER_POOL_MODE=transaction

# Maximum number of client connections PgBouncer will accept at once
PGBOUNCER_MAX_CLIENT_CONN=1000

# Server connections maintained per (database, user) pair
# Should be <= PostgreSQL max_connections minus overhead
PGBOUNCER_DEFAULT_POOL_SIZE=50

# Minimum idle server connections to keep open per pool
PGBOUNCER_MIN_POOL_SIZE=5

# Extra server connections reserved for burst traffic
PGBOUNCER_RESERVE_POOL_SIZE=10

# Seconds a client waits before a reserve pool connection is used
PGBOUNCER_RESERVE_POOL_TIMEOUT=5

# TLS enforcement for client → PgBouncer connections:
#   disable     — no TLS (not recommended in production)
#   allow       — TLS optional
#   require     — TLS required, client does not verify the server certificate
#   verify-ca   — TLS required, client verifies the CA certificate
#   verify-full — TLS required, client verifies CA + server hostname
PGBOUNCER_TLS_SSLMODE=require

# CPU limit for the PgBouncer container
PGBOUNCER_CPUS=0.5

# Memory limit for the PgBouncer container
PGBOUNCER_MEMORY=256M
